  return err && Array.isArray(err.issues);
};

export const handleApiErrors = (): MiddlewareObj => {
  return {
    onError: (request) => {
      const error = request.error;
      const cause = (error as any)?.cause;

      // ✅ Zod validation error
      if (isZodError(cause)) {
        request.response = {
          statusCode: 400,
          body: JSON.stringify({
            message: 'Validation Failed',
            errors: cause.issues,
          }),
        };
        return;
