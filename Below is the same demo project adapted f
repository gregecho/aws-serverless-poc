      if (error?.name === 'ParseError') {
        request.response = {
          statusCode: 400,
          body: JSON.stringify({
            message: 'Invalid JSON format',
          }),
        };
        return;
      }

      // ✅ fallback
      request.response = {
        statusCode: 500,
        body: JSON.stringify({
          message: 'Internal Server Error',
        }),
      };
    },
  };
};


