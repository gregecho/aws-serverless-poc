{
  "name": "aws-serverless-infrastructure",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "serverless offline --reloadHandler --verbose",
    "deploy": "serverless deploy",
    "deploy:prod": "serverless deploy --stage prod",
    "remove": "serverless remove",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:create-tables": "tsx src/scripts/create-tables.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:gen": "tsx ./src/docs/gen-docs.ts",
    "docs:preview": "pnpm docs:gen && redocly preview",
    "docs:build": "pnpm docs:gen && redocly build-docs openapi.yaml -o index.html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@aws-lambda-powertools/logger": "^2.31.0",
    "@aws-lambda-powertools/parser": "^2.31.0",
    "@aws-sdk/client-dynamodb": "^3.1010.0",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/lib-dynamodb": "^3.1010.0",
    "@middy/core": "^7.1.7",
    "@middy/http-error-handler": "^7.1.7",
    "@middy/http-header-normalizer": "^7.2.1",
    "@middy/http-json-body-parser": "^7.1.7",
    "add": "^2.0.6",
    "axios": "^1.13.6",
    "middy": "^0.36.0",
    "pnpm": "^10.32.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@redocly/cli": "^2.24.0",
    "@serverless/typescript": "^4.30.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "nock": "^14.0.11",
    "serverless": "^4.33.0",
    "serverless-offline": "^14.5.0",
    "swagger-ui-dist": "^5.32.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "yaml": "^2.8.2"
  }
}
